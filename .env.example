# =============================================================================
# Shopify App Credentials
# Obtain from: Partner Dashboard → Apps → Your App → API credentials
# =============================================================================
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Public URL of the app (tunnel URL when running `shopify app dev`)
# Example: https://your-tunnel.trycloudflare.com
SHOPIFY_APP_URL=

# =============================================================================
# Database
# Docker Compose default: postgres://postgres:postgres@localhost:5432/discount_optimizer
# =============================================================================
DATABASE_URL=postgres://postgres:postgres@localhost:5432/discount_optimizer

# Encryption key for pgcrypto (access_token at rest)
# Generate with: openssl rand -base64 32
DB_ENCRYPTION_KEY=

# =============================================================================
# Redis
# Docker Compose default: redis://localhost:6379/0
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# LLM (Phase 3+)
# =============================================================================
ANTHROPIC_API_KEY=
# Options: anthropic | openai (defaults to anthropic)
LLM_PROVIDER=anthropic
OPENAI_API_KEY=

# =============================================================================
# Internal service URLs (used by the Remix app to call the Python engine)
# =============================================================================
ENGINE_URL=http://localhost:8000

# Internal API key for service-to-service auth (Remix ↔ FastAPI)
# Generate with: openssl rand -hex 32
INTERNAL_API_KEY=

# =============================================================================
# Celery
# =============================================================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# =============================================================================
# Observability (Phase 6)
# =============================================================================
SENTRY_DSN=
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false

# =============================================================================
# Stripe Billing (Phase 6)
# =============================================================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# =============================================================================
# Environment
# =============================================================================
NODE_ENV=development
PYTHON_ENV=development
ENGINE_VERSION=rules_v1
