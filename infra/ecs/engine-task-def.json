{
  "family": "discount-optimizer-engine",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/discount-optimizer-task-role",
  "containerDefinitions": [
    {
      "name": "engine",
      "image": "ACCOUNT_ID.dkr.ecr.us-east-1.amazonaws.com/discount-optimizer-engine:latest",
      "essential": true,
      "portMappings": [
        { "containerPort": 8000, "protocol": "tcp" }
      ],
      "secrets": [
        { "name": "DATABASE_URL",      "valueFrom": "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:discount-optimizer/DATABASE_URL" },
        { "name": "REDIS_URL",         "valueFrom": "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:discount-optimizer/REDIS_URL" },
        { "name": "INTERNAL_API_KEY",  "valueFrom": "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:discount-optimizer/INTERNAL_API_KEY" },
        { "name": "ANTHROPIC_API_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:discount-optimizer/ANTHROPIC_API_KEY" },
        { "name": "SENTRY_DSN",        "valueFrom": "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:discount-optimizer/SENTRY_DSN" }
      ],
      "environment": [
        { "name": "PYTHON_ENV", "value": "production" }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:8000/health || exit 1"],
        "interval": 15,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 20
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/discount-optimizer-engine",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
